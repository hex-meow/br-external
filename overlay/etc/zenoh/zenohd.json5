// Robot-local zenoh router(P4 v2:default-allow + 定点 deny,2026-07-09 板上矩阵验证)。
// 模型:LAN 与 robot 级 API 全互动是产品能力(session 仲裁才是控制权语义,04);
// 需要网络层保护的东西按设计收敛在两处 —— hw/**(LAN 只读)与总线电源(根本不上
// 网络面:unixsock + 文件权限,09 §6)。default allow 让「漏放行」类 bug(如订阅下发
// 是 egress put)整类消失;代价是 fail-open:未来新增敏感 key 必须记得加 deny,
// 或按设计规则放进 hw/。adminspace 写有独立开关(默认 false),不受此影响。
{
  listen: {
    // 唯一 LAN 入口;Linux 默认 net.ipv6.bindv6only=0 时一个 IPv6-any socket
    // 同时接受 IPv6 与 IPv4。这样保留 IPv4/DHCP/IPv4LL,也允许通过 IPv6
    // link-local 直连;本机进程仍一律 client 连 127.0.0.1(零监听零 scouting)。
    endpoints: ["tcp/[::]:7447"],
  },
  scouting: {
    // router 侧保持开:上位机 GUI/桥靠组播发现机器人(05 决策 6)。
    // 开机早于网络/换网后的组播与 locator 刷新由 zenohd-netwatch 负责。
    multicast: { enabled: true },
    gossip: { enabled: true },
  },
  access_control: {
    enabled: true,
    default_permission: "allow",
    rules: [
      {
        id: "lan-hw-readonly",             // controller 级硬件:LAN 只读(09 §5)
        key_exprs: ["hexmeow/*/hw/**"],
        messages: ["put", "delete", "liveliness_token"],
        flows: ["ingress"],
        permission: "deny",
      },
      {
        id: "lan-no-queryable",            // 防冒充 RPC 服务端劫持查询
        key_exprs: ["hexmeow/**", "bench/**"],
        messages: ["declare_queryable"],
        flows: ["ingress"],
        permission: "deny",
      },
    ],
    subjects: [
      { id: "lan", interfaces: ["end0", "eth0", "wlan0"] },
    ],
    policies: [
      { id: "p-lan", rules: ["lan-hw-readonly", "lan-no-queryable"], subjects: ["lan"] },
    ],
  },
}
