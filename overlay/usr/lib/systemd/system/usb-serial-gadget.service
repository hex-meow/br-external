[Unit]
Description=USB Serial Gadget
Requires=sys-kernel-config.mount
After=sys-kernel-config.mount
Before=serial-getty@ttyGS0.service

[Service]
Type=oneshot
User=root
Restart=on-failure
RestartSec=3s
ExecStart=/usr/bin/usb-serial-gadget
ExecStop=/usr/bin/usb-serial-gadget stop
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
RequiredBy=serial-getty@ttyGS0.service
