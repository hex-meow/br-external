config BR2_PACKAGE_HEX_WIFI
	bool "hex-wifi"
	depends on BR2_USE_MMU
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
	select BR2_PACKAGE_HOST_RUSTC
	select BR2_PACKAGE_WPA_SUPPLICANT
	select BR2_PACKAGE_WPA_SUPPLICANT_CTRL_IFACE
	select BR2_PACKAGE_WPA_SUPPLICANT_NL80211
	help
	  Public Wi-Fi provisioning service and local CLI for Hex Meow
	  controllers. It owns Wi-Fi configuration transactions and exposes
	  a bounded request/reply protocol over a protected Unix socket. The
	  production backend uses the native wpa_supplicant control socket.

	  https://github.com/hex-meow/hex-wifi
